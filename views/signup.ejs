<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Fitzone — Sign Up</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@300;400;500;600;700&family=Barlow+Condensed:wght@400;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/signup.css">

</head>
<body>

  <!-- Ambient background -->
  <div class="bg-mesh"></div>
  <div class="bg-grid"></div>
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>

  <!-- Main content -->
  <div class="page-wrap">

    <!-- Brand header -->
    <div class="brand-header">
      <div class="brand-logo">
        <span class="bolt">⚡</span>
        <span class="brand-name">Fitzone</span>
      </div>
      <div class="brand-tagline">Find gyms <span>near you</span> · Subscribe instantly</div>
    </div>

    <!-- Signup card -->
    <div class="login-container">

      <!-- Card header -->
      <div class="login-header">
        <div class="login-icon">🏋️</div>
        <h1>Create Your Account</h1>
        <p>Join thousands training smarter with Fitzone</p>
      </div>

      <!-- Success flash -->
      <div class="success-message" id="successMessage">
        🎉 Account created! Welcome to Fitzone. Redirecting…
      </div>

      <form id="signupForm" >

        <!-- ── Full Name ───────────────────────────── -->
        <div class="form-group">
          <label for="fullName">Full Name</label>
          <div class="input-wrapper">
            <span class="input-icon">🧑</span>
            <input type="text" id="fullName" name="fullName"
              placeholder="Your full name" autocomplete="name" />
          </div>
          <div class="error-message" id="nameError"></div>
        </div>

        <!-- ── Email + Verify ─────────────────────── -->
        <div class="form-group">
          <label for="email">Email Address</label>
          <div class="input-wrapper has-verify" id="emailWrapper">
            <span class="input-icon">📧</span>
            <input type="email" id="email" name="email"
              placeholder="you@example.com" autocomplete="email" />
            <button type="button" class="verify-btn" id="emailVerifyBtn"
              onclick="sendOtp('email')">Verify</button>
          </div>
          <!-- OTP slide-down -->
          <div class="otp-section" id="emailOtpSection">
            <div class="otp-inner">
              <input type="text" id="emailOtp" maxlength="6"
                placeholder="• • • • • •" inputmode="numeric" />
              <button type="button" class="otp-submit-btn"
                onclick="verifyOtp('email')">Confirm</button>
            </div>
          </div>
          <!-- Verification status -->
          <div class="verify-status" id="emailStatus"></div>
          <div class="error-message" id="emailError"></div>
        </div>

        

        <!-- ── Create Password ────────────────────── -->
        <div class="form-group">
          <label for="password">Create Password</label>
          <div class="input-wrapper" id="passwordWrapper">
            <span class="input-icon">🔒</span>
            <input type="password" id="password" name="password"
              placeholder="Minimum 8 characters" autocomplete="new-password" />
            <span class="password-toggle" id="passwordToggle"
              title="Toggle visibility">👁️</span>
          </div>
          <!-- Strength meter -->
          <div class="tw-mt-2" id="strengthMeter" style="display:none">
            <div style="
              height:4px; border-radius:4px;
              background: rgba(255,255,255,0.07);
              overflow:hidden;
            ">
              <div id="strengthBar" style="
                height:100%; width:0%; border-radius:4px;
                transition: width 0.4s ease, background 0.4s ease;
              "></div>
            </div>
            <span id="strengthLabel" style="
              font-size:0.7rem; letter-spacing:0.06em; text-transform:uppercase;
              margin-top:0.3rem; display:block; color:var(--text-muted);
            "></span>
          </div>
          <div class="error-message" id="passwordError"></div>
        </div>

        <!-- ── Submit ──────────────────────────────── -->
        <button type="submit" class="login-button"  onclick="handleSubmit()" id="signupButton" style="margin-top:0.4rem">
          <span>🚀 Start Your Fitness Journey</span>
        </button>

      </form>


      <div class="signup-link">
        Already a member? <a href="/login">Log in here</a>
      </div>
    </div><!-- /.login-container -->

    <!-- Trust perks -->
    <div class="perks-bar">
      <div class="perk"><span class="icon">🔒</span> Secure & Private</div>
      <div class="perk"><span class="icon">⚡</span> Instant Access</div>
      <div class="perk"><span class="icon">🏙️</span> 500+ Gyms Nearby</div>
    </div>

  </div><!-- /.page-wrap -->

 <script>
  /**
 * ─────────────────────────────────────────────────────────────────
 * Fitzone Signup — Optimized Frontend Logic
 * ─────────────────────────────────────────────────────────────────
 */

// ── State management ────────────────────────────────────────────────
const state = {
  email: { verified: false }
};

// ── Real-time Error Clearing ────────────────────────────────────────
// This ensures that when a user starts fixing an error, the red text disappears.
document.querySelectorAll('input').forEach(input => {
  input.addEventListener('input', (e) => {
    const errorEl = document.getElementById(`${e.target.id}Error`) || 
                    (e.target.id === 'fullName' ? document.getElementById('nameError') : null);
    if (errorEl) errorEl.textContent = '';
  });
});

// ── Send OTP Logic ──────────────────────────────────────────────────
async function sendOtp(field) {
  const val = document.getElementById(field).value.trim();
  const statusEl = document.getElementById(`${field}Status`);
  const btn = document.getElementById(`${field}VerifyBtn`);
  
  if (!val || !val.includes('@')) {
    showError(document.getElementById(`${field}Error`), "Please enter a valid email");
    return;
  }

  // UI Feedback
  btn.disabled = true;
  btn.textContent = "Sending...";
  showStatus(statusEl, 'loading', 'Sending OTP to your inbox...');

  try {
    const res = await fetch('/generate-email-otp', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ [field]: val ,type:'signup'})
    });

    const data = await res.json();

    if (res.ok) {
      document.getElementById(`${field}OtpSection`).classList.add('open');
      showStatus(statusEl, 'success', 'OTP Sent Successfully');
      btn.textContent = "Resend?";
      btn.disabled = false;
    } else {
      showStatus(statusEl, 'fail', data.message || "Failed to send OTP");
      btn.disabled = false;
      btn.textContent = "Verify";
    }
  } catch (err) {
    showStatus(statusEl, 'fail', 'Network error. Try again.');
    btn.disabled = false;
  }
}

// ── Verify OTP Logic ────────────────────────────────────────────────
async function verifyOtp(field) {
  const otp = document.getElementById(`${field}Otp`).value.trim();
  const val = document.getElementById(field).value.trim();
  const statusEl = document.getElementById(`${field}Status`);
  const wrapEl = document.getElementById(`${field}Wrapper`);

  if (otp.length !== 6) {
    showStatus(statusEl, 'fail', "Enter 6-digit OTP");
    return;
  }

  try {
    const res = await fetch('/verify-email', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ [field]: val, otp })
    });

    const data = await res.json();

    if (res.ok) {
      showStatus(statusEl, 'success', 'Email Verified ✅');
      state[field].verified = true;
      
      // Lock UI
      wrapEl.classList.add('verified');
      document.getElementById(`${field}OtpSection`).classList.remove('open');
      document.getElementById(field).readOnly = true; // Prevent changing email after verification
      const verifyBtn = document.getElementById(`${field}VerifyBtn`);
      verifyBtn.disabled = true;
      verifyBtn.textContent = "Verified ✅";
      verifyBtn.style.background = "var(--accent-green)";
    } else {
      showStatus(statusEl, 'fail', data.message || "Invalid OTP");
    }
  } catch (err) {
    showStatus(statusEl, 'fail', 'Verification failed');
  }
}

// ── Password Strength & Toggle (Existing logic is good) ──────────────
document.getElementById('passwordToggle').addEventListener('click', function () {
  const pwd = document.getElementById('password');
  pwd.type = pwd.type === 'password' ? 'text' : 'password';
  this.textContent = pwd.type === 'text' ? '👁️' : '🙈';
});

// ── Final Form Submission ───────────────────────────────────────────
document.getElementById('signupForm').addEventListener('submit', async function (e) {
  e.preventDefault();

  // Clear previous errors
  document.querySelectorAll('.error-message').forEach(el => el.textContent = '');

  const name = document.getElementById('fullName').value.trim();
  const email = document.getElementById('email').value.trim();
  const password = document.getElementById('password').value;
  const btn = document.getElementById('signupButton');

  // Frontend Validation
  let hasError = false;
  if (!name) { showError(document.getElementById('nameError'), "Name is required"); hasError = true; }
  if (!state.email.verified) { showError(document.getElementById('emailError'), "Verification required"); hasError = true; }
  if (password.length < 8) { showError(document.getElementById('passwordError'), "Minimum 8 characters required"); hasError = true; }

  if (hasError) return;

  // Process Signup
  btn.disabled = true;
  const originalText = btn.innerHTML;
  btn.innerHTML = `<span>⏳ Forging your account...</span>`;

  try {
    const res = await fetch('/signup', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, email, password })
    });

    const data = await res.json();

    if (res.ok) {
      const successEl = document.getElementById('successMessage');
      successEl.textContent = "🎉 " + data.message;
      successEl.classList.add('show');
      btn.innerHTML = `<span>✅ Welcome to the Team!</span>`;
      btn.style.background = "var(--accent-green)";
      
      // Smooth Redirection
      setTimeout(() => { window.location.href = '/'; }, 1000);
    } else {
      // Backend validation error (e.g. User already exists)
      showError(document.getElementById('emailError'), data.message);
      btn.disabled = false;
      btn.innerHTML = originalText;
    }
  } catch (err) {
    showError(document.getElementById('emailError'), "Connection lost. Please try again.");
    btn.disabled = false;
    btn.innerHTML = originalText;
  }
});

// Helper Functions
function showError(el, msg) { el.textContent = msg; el.style.color = "#ff3b3b"; }
function showStatus(el, type, msg) {
  el.className = `verify-status show ${type}`;
  el.textContent = msg;
}
 </script>

</body>
</html>
