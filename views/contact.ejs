<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Profile | FitZone</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@300;400;600;700&family=Barlow+Condensed:wght@400;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  </head>
  <body>
<%-include('header')%>




<main class="section-pad pt-5">
  <div class="section-wrap">
    <div class="text-center mb-16 reveal">
      <div class="section-label mb-3">📞 Get In Touch</div>
      <h1 class="section-title">We're Here to Help</h1>
      <p class="section-sub mx-auto mt-4">Have questions about memberships, franchise opportunities, or technical support? Our elite team is standing by.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
      
      <div class="glass-card p-8 reveal-left">
        <h3 class="condensed text-2xl font-bold mb-8 tracking-wider">CONTACT INFO</h3>
        
        <div class="space-y-8 mb-12">
          <div class="flex items-center gap-5">
            <div class="social-icon" style="cursor: default; width: 48px; height: 48px; font-size: 1.2rem;">📧</div>
            <div>
              <p class="text-[10px] text-accent font-bold uppercase tracking-[0.2em] mb-1">Email Us</p>
              <p class="text-white font-medium">hello@fitzone.in</p>
            </div>
          </div>

          <div class="flex items-center gap-5">
            <div class="social-icon" style="cursor: default; width: 48px; height: 48px; font-size: 1.2rem;">📞</div>
            <div>
              <p class="text-[10px] text-accent font-bold uppercase tracking-[0.2em] mb-1">Call Support</p>
              <p class="text-white font-medium">+91 98765 43210</p>
            </div>
          </div>

          <div class="flex items-center gap-5">
            <div class="social-icon" style="cursor: default; width: 48px; height: 48px; font-size: 1.2rem;">📍</div>
            <div>
              <p class="text-[10px] text-accent font-bold uppercase tracking-[0.2em] mb-1">Headquarters</p>
              <p class="text-white font-medium">Jubilee Hills, Hyderabad — 500033</p>
            </div>
          </div>
        </div>

        <h3 class="condensed text-sm font-bold text-muted tracking-widest uppercase mb-6">Follow the Grind</h3>
        <div class="flex gap-4">
          <a href="#" class="social-icon">📸</a>
          <a href="#" class="social-icon">🐦</a>
          <a href="#" class="social-icon">▶️</a>
          <a href="#" class="social-icon">💼</a>
          <a href="#" class="social-icon">💬</a>
        </div>
      </div>

      <div class="glass-card p-8 reveal-right">
        <h3 class="condensed text-2xl font-bold mb-8 tracking-wider">SEND A MESSAGE</h3>

        <div id="contactSuccess" style="display:none;" class="mb-6 p-4 rounded-xl bg-accent-green/10 border border-accent-green/30 text-accent-green text-sm text-center">
          ✅ Message sent! We'll get back to you within 24 hours.
        </div>

        <div class="flex flex-col gap-5">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
              <label class="form-label">Full Name</label>
              <input class="form-input" id="contactName" placeholder="Arjun Mehta" type="text"/>
            </div>
            <div>
              <label class="form-label">Email Address</label>
              <input class="form-input" id="contactEmail" placeholder="arjun@example.com" type="email"/>
            </div>
          </div>

          <div>
            <label class="form-label">Inquiry Subject</label>
            <select class="form-input" id="contactSubject" style="cursor:pointer;">
              <option value="" style="background:#0d1421;">Select a topic</option>
              <option style="background:#0d1421;">Membership Inquiry</option>
              <option style="background:#0d1421;">Franchise Opportunity</option>
              <option style="background:#0d1421;">Technical Support</option>
              <option style="background:#0d1421;">General Feedback</option>
            </select>
          </div>

          <div>
            <label class="form-label">How can we help?</label>
            <textarea class="form-input h-32" id="contactMsg" placeholder="Type your message here..."></textarea>
          </div>

          <button class="btn-primary w-full justify-center py-4 mt-2" onclick="submitContact()">
            <span>📩 Send Secure Message</span>
          </button>
        </div>
      </div>

    </div>
  </div>
</main>



<%- include('footer') %>
</body>
</html>