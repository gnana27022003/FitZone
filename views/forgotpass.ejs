<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Fitzone — Forgot Password</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@300;400;500;600;700&family=Barlow+Condensed:wght@400;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/forgotpass.css">

</head>
<body>

  <!-- Ambient background -->
  <div class="bg-mesh"></div>
  <div class="bg-grid"></div>
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>

  <div class="page-wrap">

    <!-- Brand -->
    <div class="brand-header">
      <div class="brand-logo">
        <span class="bolt">⚡</span>
        <span class="brand-name">Fitzone</span>
      </div>
      <div class="brand-tagline">Find gyms <span>near you</span> · Subscribe instantly</div>
    </div>

    <!-- Card -->
    <div class="login-container">

      <div class="login-header">
        <div class="login-icon" id="cardIcon">🔑</div>
        <h1 id="cardTitle">Forgot Password?</h1>
        <p id="cardSubtitle">No worries — enter your registered email and<br>we'll send you a verification code.</p>
      </div>

      <!-- Success flash (shown after password reset) -->
      <div class="success-message" id="successMessage">
        🎉 Password reset successfully! Redirecting to login…
      </div>

      <!-- ── Step 1 : Email + OTP ─────────────────────── -->
      <div id="step1">

        <div class="form-group">
          <label for="email">Email Address</label>
          <div class="input-wrapper has-verify" id="emailWrapper">
            <span class="input-icon">📧</span>
            <input type="email" id="email" name="email"
              placeholder="you@example.com" autocomplete="email" />
            <button type="button" class="verify-btn" id="emailVerifyBtn"
              onclick="sendOtp()">Verify</button>
          </div>

          <!-- OTP slide-down -->
          <div class="otp-section" id="emailOtpSection">
            <div class="otp-inner">
              <input type="text" id="emailOtp" maxlength="6"
                placeholder="• • • • • •" inputmode="numeric" />
              <button type="button" class="otp-submit-btn" id="otpConfirmBtn"
                onclick="verifyOtp()">Confirm</button>
            </div>
          </div>

          <!-- Verification status -->
          <div class="verify-status" id="emailStatus"></div>
          <div class="error-message" id="emailError"></div>
        </div>

      </div>
      <!-- /step1 -->

      <!-- ── Step 2 : Reset Password (slides in after verify) ── -->
      <div class="reset-section" id="resetSection">

        <div class="reset-divider"><span>🔐 Set your new password</span></div>

        <!-- New Password -->
        <div class="form-group" style="margin-bottom:1rem">
          <label for="newPassword">New Password</label>
          <div class="input-wrapper" id="newPassWrapper">
            <span class="input-icon">🔒</span>
            <input type="password" id="newPassword"
              placeholder="Minimum 8 characters" autocomplete="new-password" />
            <span class="password-toggle" id="newPassToggle" title="Toggle visibility">👁️</span>
          </div>
          <!-- Strength meter -->
          <div id="strengthMeter" style="display:none; margin-top:0.5rem">
            <div style="height:4px;border-radius:4px;background:rgba(255,255,255,0.07);overflow:hidden">
              <div id="strengthBar" style="height:100%;width:0%;border-radius:4px;transition:width 0.4s ease,background 0.4s ease;"></div>
            </div>
            <span id="strengthLabel" style="font-size:0.7rem;letter-spacing:0.06em;text-transform:uppercase;margin-top:0.3rem;display:block;color:var(--text-muted);"></span>
          </div>
          <div class="error-message" id="newPassError"></div>
        </div>

        <!-- Confirm Password -->
        <div class="form-group" style="margin-bottom:1.2rem">
          <label for="confirmPassword">Confirm Password</label>
          <div class="input-wrapper">
            <span class="input-icon">🔑</span>
            <input type="password" id="confirmPassword"
              placeholder="Re-enter your password" autocomplete="new-password" />
            <span class="password-toggle" id="confirmPassToggle" title="Toggle visibility">👁️</span>
          </div>
          <div class="error-message" id="confirmPassError"></div>
        </div>

        <!-- Reset button -->
        <button type="button" class="login-button" id="resetBtn" onclick="resetPassword()">
          <span>🔄 Reset Password</span>
        </button>

      </div>
      <!-- /resetSection -->

      <div class="signup-link">
        Remembered it? <a href="/login">Back to Login</a>
      </div>

    </div><!-- /.login-container -->

    <!-- Perks -->
    <div class="perks-bar">
      <div class="perk"><span class="icon">🔒</span> Secure & Private</div>
      <div class="perk"><span class="icon">⚡</span> Instant Access</div>
      <div class="perk"><span class="icon">🏙️</span> 500+ Gyms Nearby</div>
    </div>

  </div><!-- /.page-wrap -->

<script>
  const state = {
    email: '',
    verified: false
};

// ── FIXED: Password Visibility Toggles ──────────────────────────
// Logic to make the👁️/🙈 icons functional
document.getElementById('newPassToggle').addEventListener('click', function () {
    const input = document.getElementById('newPassword');
    input.type = input.type === 'password' ? 'text' : 'password';
    this.textContent = input.type === 'text' ? '👁️' : '🙈';
});

document.getElementById('confirmPassToggle').addEventListener('click', function () {
    const input = document.getElementById('confirmPassword');
    input.type = input.type === 'password' ? 'text' : 'password';
    this.textContent = input.type === 'text' ? '👁️' : '🙈';
});

// ── Step 1: Send OTP ─────────────────────────────────────────────
async function sendOtp() {
    const emailEl = document.getElementById('email');
    const btnEl = document.getElementById('emailVerifyBtn');
    const statusEl = document.getElementById('emailStatus');
    const errorEl = document.getElementById('emailError');
    const email = emailEl.value.trim();

    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        errorEl.textContent = 'Enter a valid email address';
        return;
    }
    errorEl.textContent = '';
    btnEl.disabled = true;
    btnEl.textContent = '...';

    try {
        const res = await fetch('/generate-email-otp', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, type: 'forgot' }) // ADDED TYPE HERE
        });
        const data = await res.json();

        if (res.ok) {
            state.email = email;
            document.getElementById('emailOtpSection').classList.add('open');
            statusEl.className = 'verify-status show success';
            statusEl.textContent = 'OTP Sent to ' + email;
            btnEl.textContent = 'Resend';
        } else {
            errorEl.textContent = data.message;
            btnEl.textContent = 'Verify';
        }
    } catch (err) {
        errorEl.textContent = 'Server error. Try again.';
    } finally {
        btnEl.disabled = false;
    }
}

// ── Step 2: Verify OTP ───────────────────────────────────────────
async function verifyOtp() {
    const otpInput = document.getElementById('emailOtp');
    const confirmBtn = document.getElementById('otpConfirmBtn');
    const statusEl = document.getElementById('emailStatus');
    const code = otpInput.value.trim();

    confirmBtn.disabled = true;
    confirmBtn.textContent = '...';

    try {
        const res = await fetch('/verify-email', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: state.email, otp: code })
        });
        const data = await res.json();

        if (res.ok) {
            state.verified = true;
            statusEl.className = 'verify-status show success';
            statusEl.textContent = 'Email Verified ✅';
            
            document.getElementById('emailOtpSection').classList.remove('open');
            document.getElementById('emailWrapper').classList.add('verified');
            document.getElementById('email').disabled = true;
            document.getElementById('emailVerifyBtn').disabled = true;
            
            setTimeout(() => {
                document.getElementById('resetSection').classList.add('open');
                document.getElementById('cardTitle').textContent = 'Set New Password';
            }, 400);
        } else {
            statusEl.className = 'verify-status show fail';
            statusEl.textContent = data.message;
        }
    } catch (err) {
        statusEl.textContent = 'Verification failed.';
    } finally {
        confirmBtn.disabled = false;
        confirmBtn.textContent = 'Confirm';
    }
}

// ── Step 3: Final Reset ──────────────────────────────────────────
async function resetPassword() {
    const password = document.getElementById('newPassword').value;
    const confirm = document.getElementById('confirmPassword').value;
    const btn = document.getElementById('resetBtn');
    const errorEl = document.getElementById('confirmPassError');
    const newPassErrorEl = document.getElementById('newPassError');

    // Reset error messages
    errorEl.textContent = '';
    newPassErrorEl.textContent = '';

    // Validation
    if (password.length < 8) {
        newPassErrorEl.textContent = 'Password must be at least 8 characters';
        return;
    }
    
    if (password !== confirm) {
        errorEl.textContent = 'Passwords do not match';
        return;
    }

    // UI Feedback
    btn.disabled = true;
    btn.querySelector('span').textContent = 'Resetting...';

    try {
        const res = await fetch('/reset-password', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: state.email, password })
        });
        
        const data = await res.json();

        if (res.ok) {
            document.getElementById('successMessage').classList.add('show');
            btn.style.background = 'var(--accent-green)';
            btn.querySelector('span').textContent = 'Success!';
            
            // FIXED: Valid integer for setTimeout
            setTimeout(() => { 
                window.location.href = '/login'; 
            }, 1000); 
        } else {
            errorEl.textContent = data.message;
            btn.disabled = false;
            btn.querySelector('span').textContent = 'Reset Password';
        }
    } catch (err) {
        errorEl.textContent = 'Error updating password.';
        btn.disabled = false;
        btn.querySelector('span').textContent = 'Reset Password';
    }
}
</script>
</body>
</html>
