<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>FitZone — Forge Your Legend</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&family=Barlow+Condensed:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>

  <link rel="stylesheet" href="/home.css">
</head>
<body>

<div class="bg-mesh"></div>
<div class="bg-grid"></div>

<%- include('header', { page: 'home' }) %>
<header class="video-hero-container" id="home">
    <video autoplay muted loop playsinline id="bgVideo">
        <source src="/Gym_Workout_Video_Generation_Request.webm" type="video/mp4">
    </video>
    <div class="hero-vignette"></div>
    
    <div class="relative z-10 text-center px-4">
        <% if (!isLoggedIn) { %>
            <div class="inline-block px-4 py-1 mb-6 rounded-full border border-accent/30 bg-accent/10 condensed text-accent text-xs tracking-widest uppercase"> Forge Your Legend Today </div>
            <h1 class="brand-font text-5xl sm:text-7xl md:text-9xl text-white leading-tight md:leading-none mb-6 hero-text-pop">
                <span class="typewriter">LIMITLESS <span class="text-[#ff4d00] italic">POTENTIAL</span></span>
            </h1>
            <p class="text-white font-extrabold max-w-xl mx-auto mb-10 text-lg md:text-xl hero-text-pop">
                Join the most aggressive fitness network in India. Stop existing. Start evolving.
            </p>
            <div class="flex flex-col md:flex-row gap-4 justify-center">
                <a href="/signup" class="btn-hot px-10 py-4 rounded-xl text-lg uppercase tracking-wider"><span>Start 7-Day Trial</span></a>
            </div>

        <% } else if (isLoggedIn && (!subscription || subscription.status !== 'active')) { %>
            
            <h1 class="brand-font text-6xl md:text-9xl text-white leading-none mb-6 hero-text-pop">
                <span class="typewriter">ACTIVATE <span class="text-[#ff4d00] italic">ELITE</span> ACCESS</span>
            </h1>
            <p class="text-white font-extrabold max-w-xl mx-auto mb-10 text-lg md:text-xl hero-text-pop">
                Welcome back. The weights are waiting. Choose your tier and enter the zone.
            </p>
            <div class="flex flex-col md:flex-row gap-4 justify-center">
                <a href="#plans" class="btn-hot px-10 py-4 rounded-xl text-lg uppercase tracking-wider"><span>Activate Plan</span></a>
            </div>

        <% } else { %>
            <h1 class="brand-font text-5xl sm:text-7xl md:text-9xl text-white leading-tight md:leading-none mb-6 hero-text-pop">
                <span class="typewriter">WELCOME BACK, <span class="text-[#00b4ff] italic">ATHLETE</span></span>
            </h1>
            <p class="text-white font-extrabold max-w-xl mx-auto mb-10 text-lg md:text-xl hero-text-pop">
                Your <%= subscription.planName %> access is live. Outperform your past self.
            </p>
            <div class="flex flex-col md:flex-row gap-4 justify-center">
                <a href="/profile" class="btn-hot px-10 py-4 rounded-xl text-lg uppercase tracking-wider"><span>Enter Dashboard</span></a>
            </div>
        <% } %>
    </div>
</header>

<section class="relative z-10 py-20 -mt-20">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="glass-card p-8 text-center reveal">
            <div class="counter-num" data-target="<%= locations.length %>">0</div>
            <div class="condensed text-muted tracking-widest uppercase text-xs">Branches Nationwide</div>
        </div>
        <div class="glass-card p-8 text-center reveal">
            <div class="counter-num" data-target="128000">0</div>
            <div class="condensed text-muted tracking-widest uppercase text-xs">Elite Members</div>
        </div>
        <div class="glass-card p-8 text-center reveal">
            <div class="counter-num" data-target="42000">0</div>
            <div class="condensed text-muted tracking-widest uppercase text-xs">Success Stories</div>
        </div>
        <div class="glass-card p-8 text-center reveal">
            <div class="counter-num" data-target="3200">0</div>
            <div class="condensed text-muted tracking-widest uppercase text-xs">Pro Trainers</div>
        </div>
    </div>
</section>
<section class="py-24" id="features">
    <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
            <h2 class="brand-font text-5xl md:text-7xl mb-4">The Elite Environment</h2>
            <p class="text-muted max-w-2xl mx-auto">We don't just provide a gym; we provide a laboratory for physical excellence.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="glass-card p-8 reveal">
                <div class="text-4xl mb-4">🏆</div>
                <h3 class="brand-font text-2xl mb-2 text-white">Modern Equipment</h3>
                <p class="text-sm text-muted">Olympic-grade bars, biomechanically optimized machines, and 24/7 biometric access.</p>
            </div>
            <div class="glass-card p-8 reveal">
                <div class="text-4xl mb-4">🎓</div>
                <h3 class="brand-font text-2xl mb-2 text-white">Expert Coaching</h3>
                <h3 class="text-sm text-muted">Work with certified performance coaches to build custom programs that get results fast.</h3>
            </div>
            <div class="glass-card p-8 reveal">
                <div class="text-4xl mb-4">🥙</div>
                <h3 class="brand-font text-2xl mb-2 text-white">Nutrition Logic</h3>
                <p class="text-sm text-muted">Personalized diet plans synced with your workout intensity to fuel your transformation.</p>
            </div>
        </div>
    </div>
</section>
<section class="py-24 bg-white/5 backdrop-blur-sm" id="plans">
    <div class="max-w-7xl mx-auto px-6">
        <h2 class="brand-font text-6xl text-center mb-16">
            <%= (subscription && subscription.status === 'active') ? 'YOUR MEMBERSHIP' : 'SELECT YOUR POWER' %>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            
            <% plans.forEach((plan, index) => { %>
                <% const isCurrentPlan = subscription && subscription.planId.toString() === plan._id.toString(); %>
                
                <div class="glass-card p-10 reveal <%= index === 1 ? 'border-accent/40 relative scale-105 shadow-[0_0_50px_rgba(0,180,255,0.15)]' : '' %> <%= isCurrentPlan ? 'border-accent-green/50' : '' %>">
                    
                    <% if(isCurrentPlan) { %>
                        <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-accent-green text-white px-6 py-1 rounded-full text-xs font-bold tracking-widest uppercase">Current Plan</div>
                    <% } else if(index === 1) { %>
                        <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-accent text-white px-6 py-1 rounded-full text-xs font-bold tracking-widest uppercase">Popular Choice</div>
                    <% } %>
                    
                    <h3 class="brand-font text-4xl mb-4 text-white uppercase"><%= plan.name %></h3>
                    <% if (isCurrentPlan) { %>
                        <a href="/profile" class="btn-primary w-full text-center bg-accent-green/20 border border-accent-green/50">
                            <span>Manage Membership</span>
                        </a>
                    <% } else { %>
                        <a href="/checkout?planId=<%= plan._id %>" class="btn-primary w-full text-center">
                            <span><%= isLoggedIn ? 'Upgrade Now' : 'Join ' + plan.name %></span>
                        </a>
                    <% } %>
                </div>
            <% }) %>

        </div>
    </div>
</section>

<section class="py-24" id="reviews">
    <div class="max-w-7xl mx-auto px-6">
        <h2 class="brand-font text-6xl text-center mb-16">The Proof</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
            <div class="glass-card p-8 reveal">
                <div class="flex items-center gap-4 mb-6">
                    <div class="w-16 h-16 rounded-full bg-accent/20 border border-accent/40 flex items-center justify-center font-bold">RM</div>
                    <div>
                        <h4 class="font-bold text-white">Rahul Mishra</h4>
                        <p class="text-xs text-accent uppercase">90 Day Transformation</p>
                    </div>
                </div>
                <p class="italic text-white/80 leading-relaxed">"Dropped 15kg of fat and gained discipline. The 24/7 access at FitZone made it impossible to find an excuse."</p>
            </div>
            <div class="glass-card p-8 reveal">
                <div class="flex items-center gap-4 mb-6">
                    <div class="w-16 h-16 rounded-full bg-accent-hot/20 border border-accent-hot/40 flex items-center justify-center font-bold">SS</div>
                    <div>
                        <h4 class="font-bold text-white">Sneha Singh</h4>
                        <p class="text-xs text-accent-hot uppercase">Powerlifting Build</p>
                    </div>
                </div>
                <p class="italic text-white/80 leading-relaxed">"Elite equipment that you won't find anywhere else. The community here pushes you beyond your limits."</p>
            </div>
        </div>
    </div>
</section>

<%- include('footer') %>

<script>
    // Reveal Observer
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // Dynamic Counter Script
    function animateCounter(el, target) {
        let current = 0;
        const duration = 2000; 
        const frameRate = 1000 / 60;
        const totalFrames = Math.round(duration / frameRate);
        const increment = target / totalFrames;

        const update = () => {
            current += increment;
            if (current < target) {
                el.innerText = Math.floor(current).toLocaleString() + "+";
                requestAnimationFrame(update);
            } else {
                el.innerText = target.toLocaleString() + "+";
            }
        };
        update();
    }

    const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(e => {
            if(e.isIntersecting && !e.target.dataset.counted) {
                e.target.dataset.counted = true;
                animateCounter(e.target, parseInt(e.target.dataset.target));
            }
        });
    }, { threshold: 0.5 });
    document.querySelectorAll('.counter-num').forEach(el => counterObserver.observe(el));
</script>
</body>
</html>