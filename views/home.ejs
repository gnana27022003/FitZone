<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>FitZone — Forge Your Legend</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&family=Barlow+Condensed:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>

  <style>
    /* ═══════════════════════════════════════════════
        CORE CSS - Retained from your original index.html
    ═══════════════════════════════════════════════ */
    :root {
      --bg-base:       #080b10;
      --bg-card:       rgba(12,18,28,0.82);
      --border-glass:  rgba(0,180,255,0.12);
      --border-glow:   rgba(0,180,255,0.45);
      --accent:        #00b4ff;
      --accent-hot:    #ff4d00;
      --accent-green:  #00e676;
      --text-primary:  #e8f2ff;
      --text-muted:    #5e7a99;
      --transition:    0.28s cubic-bezier(.4,0,.2,1);
    }

    body { font-family:'Barlow',sans-serif; background:var(--bg-base); color:var(--text-primary); overflow-x:hidden; }
    .brand-font { font-family:'Bebas Neue',sans-serif; }
    .condensed { font-family:'Barlow Condensed',sans-serif; }

    /* BACKGROUND SYSTEM */
    .bg-mesh{ position:fixed;inset:0;z-index:0;pointer-events:none; background: radial-gradient(ellipse 80% 60% at 20% 10%,rgba(0,100,220,0.13) 0%,transparent 70%), radial-gradient(ellipse 60% 50% at 80% 80%,rgba(255,77,0,0.09) 0%,transparent 70%); }
    .bg-grid{ position:fixed;inset:0;z-index:0;pointer-events:none; background-image: linear-gradient(rgba(0,180,255,0.04) 1px,transparent 1px), linear-gradient(90deg,rgba(0,180,255,0.04) 1px,transparent 1px); background-size:48px 48px; animation:gridDrift 30s linear infinite; }
    @keyframes gridDrift{to{background-position:48px 48px;}}

    /* GLASS CARD */
    .glass-card {
      background: var(--bg-card);
      border: 1px solid var(--border-glass);
      backdrop-filter: blur(22px) saturate(1.3);
      border-radius: 20px;
      transition: all var(--transition);
    }
    .glass-card:hover { border-color: rgba(0,180,255,0.3); transform: translateY(-5px); box-shadow: 0 20px 40px rgba(0,0,0,0.4); }

    /* VIDEO ENGINE FIX */
    .video-hero-container { position: relative; height: 100vh; width: 100%; overflow: hidden; display: flex; align-items: center; justify-content: center; }
    #bgVideo { position: absolute; top: 50%; left: 50%; min-width: 100%; min-height: 100%; width: auto; height: auto; z-index: -1; transform: translateX(-50%) translateY(-50%); object-fit: cover; opacity: 0.5; }
    .hero-vignette { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(8,11,16,0.8) 0%, transparent 40%, rgba(8,11,16,0.9) 90%, var(--bg-base) 100%); z-index: 0; }

    /* BUTTONS */
    .btn-primary { background: linear-gradient(135deg, #0066cc, var(--accent)); color: #fff; padding: 0.8rem 2rem; border-radius: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; transition: 0.3s; box-shadow: 0 10px 20px rgba(0,100,220,0.3); }
    .btn-primary:hover { transform: scale(1.05); box-shadow: 0 15px 30px rgba(0,180,255,0.5); }

    /* STATS COUNTER */
    .counter-num { font-family:'Bebas Neue',sans-serif; font-size: 4rem; background: linear-gradient(120deg, #fff, var(--accent)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

    /* REVEAL ANIMATIONS */
    .reveal { opacity: 0; transform: translateY(30px); transition: all 0.8s ease-out; }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    #bgVideo {
    /* ... other properties ... */
    opacity: 0.85; /* Increased from 0.5 for better clarity */
}
.hero-vignette {
    position: absolute;
    inset: 0;
    /* We reduced the black tint from 0.8/0.9 down to 0.4/0.6 */
    background: linear-gradient(to bottom, 
        rgba(8,11,16,0.5) 0%, 
        transparent 30%, 
        transparent 70%, 
        var(--bg-base) 100%);
    z-index: 0;
    pointer-events: none;
}

#bgVideo {
    position: absolute;
    top: 50%;
    left: 50%;
    min-width: 100%;
    min-height: 100%;
    width: auto;
    height: auto;
    z-index: -1;
    transform: translate(-50%, -50%);
    object-fit: cover;
    opacity: 0.99; /* High opacity for clarity */
    filter: brightness(0.75) saturate(0.9); /* Slight boost to light and color */
}
.video-hero-container h1 {
    text-shadow: 0 4px 15px rgba(0,0,0,0.8);
}
  </style>
</head>
<body>

