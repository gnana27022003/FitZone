<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Checkout | FitZone</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@300;400;600;700&family=Barlow+Condensed:wght@400;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  </head>
  <body>


<%- include('header', { page: 'checkout' }) %>

<main class="section-pad pt-10">
  <div class="section-wrap max-w-5xl">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
      <div class="lg:col-span-2 reveal-left">
  <div class="glass-card p-8">
    <h2 class="condensed text-3xl font-bold mb-8 text-accent">SECURE CHECKOUT</h2>
    
    <form action="/subscribe" method="POST" class="space-y-6">
      <input type="hidden" name="planId" value="<%= plan._id %>">

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="form-label text-xs">Full Name</label>
          <input type="text" class="form-input opacity-70 cursor-not-allowed" 
                 value="<%= user.name %>" readonly name="userName">
        </div>
        <div>
          <label class="form-label text-xs">Email Address</label>
          <input type="email" class="form-input opacity-70 cursor-not-allowed" 
                 value="<%= user.email %>" readonly name="userEmail">
        </div>
      </div>

      <div>
        <label class="form-label text-xs">Select Payment Method</label>
        <select name="paymentMethod" class="form-input bg-[#0c121c]" required>
          <option value="" disabled selected>Choose an option...</option>
          <option value="credit">Credit Card</option>
          <option value="debit">Debit Card</option>
          <option value="emi">EMI (Equated Monthly Installments)</option>
        </select>
      </div>

     

      <button type="submit" class="btn-primary w-full justify-center py-4 mt-4">
        <span>🚀 Pay ₹<%= plan.price %></span>
      </button>
    </form>
  </div>
</div>

      <div class="reveal-right">
        <div class="glass-card p-6 border-accent/20 bg-accent/5">
      <h3 class="condensed text-xl font-bold mb-6">ORDER SUMMARY</h3>
      <div class="flex justify-between mb-4">
          <span class="text-muted"><%= plan.name %></span>
          <span class="font-bold">₹<%= plan.price %></span>
      </div>
      <div class="border-t border-white/10 pt-4 flex justify-between">
          <span class="condensed text-xl font-bold">TOTAL</span>
          <span class="condensed text-2xl font-bold text-accent">₹<%= plan.price %></span>
      </div>
</div>


      </div>
    </div>
  </div>
</main>



<%- include('footer') %>
</body>
</html>