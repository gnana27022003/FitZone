<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Membership Tiers | FitZone</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@300;400;600;700&family=Barlow+Condensed:wght@400;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --accent-hot: #ff4d00;
            --accent-blue: #00b4ff;
        }
        /* Fix for structured list alignment */
        .feature-list li {
            display: grid;
            grid-template-columns: 24px 1fr;
            align-items: start;
            margin-bottom: 12px;
        }
        /* Glass card enhancement for active state */
        .card-active {
            border: 2px solid var(--accent-hot) !important;
            box-shadow: 0 0 30px rgba(255, 77, 0, 0.15);
        }
        .btn-subscribed {
            background: rgba(255, 77, 0, 0.1);
            border: 1px solid var(--accent-hot);
            color: var(--accent-hot);
            cursor: default;
            pointer-events: none;
        }
        .btn-upgrade {
            background: linear-gradient(135deg, #0066cc, var(--accent-blue));
            box-shadow: 0 4px 15px rgba(0, 180, 255, 0.3);
        }
    </style>
</head>
<body class="bg-[#080b10]">
<%- include('header', { page: 'plans' }) %>

<main class="pb-20 pt-10">
    <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16 reveal visible">
            <div class="inline-block px-4 py-1 mb-3 rounded-full border border-blue-500/30 bg-blue-500/10 condensed text-[#00b4ff] text-xs font-bold uppercase tracking-widest">
                💳 Membership Tiers
            </div>
            <h1 class="brand-font text-6xl md:text-8xl text-white mb-4">Select Your <span class="text-[#00b4ff] italic">Intensity</span></h1>
            <p class="text-gray-400 max-w-2xl mx-auto text-lg">Transparent pricing for elite performance. No hidden fees, just results.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
            <% plans.forEach(plan => { %>
                <% 
                    // Compare IDs strictly as strings
                    const isCurrentPlan = subscription && subscription.planId.toString() === plan._id.toString();
                    const hasActiveSub = subscription && subscription.status === 'active';
                %>
                
                <div class="glass-card p-10 flex flex-col transition-all duration-300 hover:translate-y-[-8px] <%= isCurrentPlan ? 'card-active' : '' %>" 
                     style="background: rgba(12, 18, 28, 0.82); border: 1px solid rgba(0, 180, 255, 0.12); border-radius: 20px; backdrop-filter: blur(20px);">
                    
                    <div class="mb-8">
                        <div class="flex justify-between items-start">
                            <h3 class="condensed text-3xl font-extrabold text-white uppercase tracking-tight"><%= plan.name %></h3>
                            <% if (isCurrentPlan) { %>
                                <span class="bg-[#ff4d00] text-white text-[10px] font-black px-2 py-1 rounded uppercase">Current</span>
                            <% } %>
                        </div>
                        <p class="text-sm text-gray-500 mt-2 font-bold uppercase tracking-widest"><%= plan.duration %> Days Access</p>
                    </div>

                    <div class="mb-10">
                        <div class="flex items-baseline gap-1">
                            <span class="brand-font text-5xl text-[#00b4ff]">₹<%= plan.price %></span>
                            <span class="text-gray-500 text-sm font-bold uppercase">One-time</span>
                        </div>
                    </div>

                    <ul class="feature-list flex-1 mb-10 text-gray-300">
                        <% plan.features.forEach(feature => { %>
                            <li>
                                <span class="text-green-500 font-bold">✓</span>
                                <span class="text-sm leading-relaxed"><%= feature %></span>
                            </li>
                        <% }) %>
                    </ul>

                    ]<div class="mt-auto">
                    <% if (isCurrentPlan) { %>
                        <div class="btn-subscribed w-full text-center py-4 rounded-xl font-black uppercase tracking-widest text-sm">
                            Subscribed
                        </div>
                    <% } else if (hasActiveSub) { %>
                        <% 
                            const isUpgrade = plan.price > subscription.price;
                            const buttonText = isUpgrade ? `Upgrade to ${plan.name}` : `Switch to ${plan.name}`;
                        %>
                        <a href="/checkout?planId=<%= plan._id %>" class="btn-upgrade block w-full text-center py-4 rounded-xl font-black text-white uppercase tracking-widest text-sm transition-all hover:brightness-110">
                            <%= buttonText %>
                        </a>
                    <% } else { %>
                        <a href="/checkout?planId=<%= plan._id %>" class="block w-full text-center py-4 rounded-xl font-black text-white uppercase tracking-widest text-sm bg-gradient-to-r from-[#0066cc] to-[#00b4ff] transition-all hover:scale-[1.02]">
                            Select Plan
                        </a>
                    <% } %>
                </div>
                </div>
            <% }) %>
        </div>
    </div>
</main>

<%- include('footer') %>

<script>
    // Simple reveal animation for cards
    const observerOptions = { threshold: 0.1 };
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                entry.target.style.opacity = '1';
                entry.target.style.transform = 'translateY(0)';
            }
        });
    }, observerOptions);

    document.querySelectorAll('.reveal').forEach(el => {
        el.style.opacity = '0';
        el.style.transform = 'translateY(20px)';
        el.style.transition = 'all 0.6s ease-out';
        observer.observe(el);
    });
</script>
</body>
</html>