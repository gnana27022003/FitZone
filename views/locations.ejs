<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Locations | FitZone</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@300;400;600;700&family=Barlow+Condensed:wght@400;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/styles.css">
  </head>
  <body>




<%- include('header', { page: 'locations' }) %>

<main class="pb-20">
  <div class="section-wrap">
    <div class="text-center mb-16 reveal visible">
      <div class="section-label mb-3 text-accent condensed tracking-widest text-xs font-bold uppercase">📍 The Zone Network</div>
      <h1 class="brand-font text-6xl md:text-7xl mb-4">500+ Locations</h1>
      <p class="text-muted max-w-2xl mx-auto">One membership, nationwide access. Find your nearest forge.</p>
    </div>

    <div class="max-w-2xl mx-auto mb-16 reveal visible">
        <div class="relative">
            <input type="text" class="w-full bg-white/5 border border-white/10 p-4 px-6 rounded-2xl text-white focus:outline-none focus:border-accent" placeholder="Search City (e.g. Hyderabad)...">
            <button class="absolute right-3 top-2 btn-nav py-2 px-6 border-none cursor-pointer"><span>Search</span></button>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <% locations.forEach((loc) => { %>
      <div class="glass-card p-8 reveal visible">
        <div class="flex justify-between items-start mb-6">
          <div>
            <div class="text-4xl mb-4">🏙️</div>
            <h3 class="condensed text-2xl font-bold uppercase tracking-tight text-white"><%= loc.areaName %></h3>
            <p class="text-xs text-muted mt-1"><%= loc.state %>, India</p>
          </div>
          <div class="bg-accent/10 border border-accent/30 text-accent text-[10px] font-bold uppercase px-3 py-1 rounded-full">Active</div>
        </div>
        
        <div class="pt-6 border-t border-white/5 flex justify-between items-center">
            <div>
                <p class="text-[10px] text-muted uppercase font-bold tracking-widest mb-1">Pincode</p>
                <p class="condensed text-xl font-bold text-accent"><%= loc.pincode %></p>
            </div>
            <a href="#" class="btn-nav bg-transparent border border-white/10 hover:border-accent lowercase px-4 py-2 text-xs"><span>View Details →</span></a>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</main>

<%- include('footer') %>



</body>
</html>







