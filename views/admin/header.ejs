<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>FitZone Admin | Control Center</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:ital,wght@0,300;0,400;0,600;0,700&family=Barlow+Condensed:wght@400;700;800&display=swap" rel="stylesheet"/>
  <style>
    /* ═══════════════════════════════════════════════
   FITZONE GLOBAL COMMAND - REFINED CSS
   ═══════════════════════════════════════════════ */

:root {
  /* Core Palette */
  --bg-base:       #080b10;
  --bg-card:       rgba(12, 18, 28, 0.75);
  --accent:        #00b4ff;
  --accent-hot:    #ff4d00;
  --accent-green:  #00e676;
  --text-primary:  #e8f2ff;
  --text-muted:    #5e7a99;
  
  /* Refined Glass Borders */
  --border-glass:  rgba(0, 180, 255, 0.12);
  --border-glow:   rgba(0, 180, 255, 0.35);
  --transition:    0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ── GLOBAL DEFAULTS ─────────────────────────── */
body {
  font-family: 'Barlow', sans-serif;
  background: var(--bg-base);
  color: var(--text-primary);
  line-height: 1.6;
  overflow-x: hidden;
}

.brand-font { font-family: 'Bebas Neue', sans-serif; letter-spacing: 0.05em; }
.condensed  { font-family: 'Barlow Condensed', sans-serif; font-weight: 700; }

/* ── DYNAMIC BACKGROUND SYSTEM ──── */
.bg-mesh {
  position: fixed; inset: 0; z-index: -2; pointer-events: none;
  background: 
    radial-gradient(ellipse 80% 60% at 20% 10%, rgba(0, 100, 220, 0.15) 0%, transparent 70%),
    radial-gradient(ellipse 60% 50% at 80% 80%, rgba(255, 77, 0, 0.1) 0%, transparent 70%);
}

.bg-grid {
  position: fixed; inset: 0; z-index: -1; pointer-events: none;
  background-image: 
    linear-gradient(var(--border-glass) 1px, transparent 1px),
    linear-gradient(90deg, var(--border-glass) 1px, transparent 1px);
  background-size: 50px 50px;
  opacity: 0.4;
}

/* ── REFINED GLASS CARDS ─────────── */
.glass-card {
  background: var(--bg-card);
  border: 1px solid var(--border-glass);
  backdrop-filter: blur(20px) saturate(1.5);
  -webkit-backdrop-filter: blur(20px) saturate(1.5);
  border-radius: 16px;
  padding: 1.5rem;
  transition: all var(--transition);
  position: relative;
  overflow: hidden;
}

.glass-card:hover {
  border-color: var(--border-glow);
  transform: translateY(-5px);
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
}

/* ── ADMIN INTERFACE COMPONENTS ──────────────── */

/* Stylish Data Tables */
.admin-table {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0 8px;
}

.admin-table th {
  padding: 12px 20px;
  color: var(--accent);
  text-transform: uppercase;
  font-size: 0.75rem;
  letter-spacing: 0.15em;
  font-family: 'Barlow Condensed', sans-serif;
}

.admin-table td {
  padding: 16px 20px;
  background: rgba(255, 255, 255, 0.02);
  border-top: 1px solid var(--border-glass);
  border-bottom: 1px solid var(--border-glass);
}

.admin-table tr td:first-child { border-left: 1px solid var(--border-glass); border-top-left-radius: 12px; border-bottom-left-radius: 12px; }
.admin-table tr td:last-child  { border-right: 1px solid var(--border-glass); border-top-right-radius: 12px; border-bottom-right-radius: 12px; }

/* Dynamic Admin Inputs */
.admin-input {
  width: 100%;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid var(--border-glass);
  padding: 0.8rem 1.2rem;
  border-radius: 10px;
  color: white;
  font-family: 'Barlow', sans-serif;
  transition: all 0.3s ease;
}

.admin-input:focus {
  outline: none;
  border-color: var(--accent);
  background: rgba(0, 180, 255, 0.08);
  box-shadow: 0 0 15px rgba(0, 180, 255, 0.2);
}

/* Status Badges */
.badge {
  padding: 4px 12px;
  border-radius: 50px;
  font-size: 10px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.badge-blue  { background: rgba(0, 180, 255, 0.15); color: var(--accent); border: 1px solid rgba(0, 180, 255, 0.3); }
.badge-green { background: rgba(0, 230, 118, 0.15); color: var(--accent-green); border: 1px solid rgba(0, 230, 118, 0.3); }
.badge-hot   { background: rgba(255, 77, 0, 0.15); color: var(--accent-hot); border: 1px solid rgba(255, 77, 0, 0.3); }

/* Stylish Button System */
.btn-action {
  padding: 8px 16px;
  border-radius: 8px;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  transition: all 0.3s ease;
  cursor: pointer;
}

.btn-edit   { color: var(--accent); border: 1px solid var(--border-glass); background: transparent; }
.btn-edit:hover { background: var(--accent); color: white; }

.btn-delete { color: var(--accent-hot); border: 1px solid rgba(255, 77, 0, 0.2); background: transparent; }
.btn-delete:hover { background: var(--accent-hot); color: white; }
/* ── ARCHITECTURAL LAYOUT ────────────────────── */
.admin-page-container {
  max-width: 1400px; /* Limits width so it doesn't look stretched on large monitors */
  margin: 0 auto;    /* Centers the entire content block */
  padding: 0 40px;   /* Creates the missing side-space (gutters) you need */
}

.section-header {
  margin-top: 4rem;
  margin-bottom: 3rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

/* Fix for the Table and Cards to ensure they don't feel "cramped" */
.admin-table-wrapper {
  margin-top: 2rem;
  padding: 10px; /* Internal breathing room */
}
/* Add this to your style.css if not already there */
.admin-page-container {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 40px;
}
.section-header {
  margin-top: 4rem;
  margin-bottom: 3rem;
}
  </style>
  
</head>
<body>
<div class="bg-mesh"></div>

<nav class="fixed top-0 w-full z-50 py-4 px-8 bg-black/40 backdrop-blur-xl border-b border-white/5 flex items-center justify-between">
    <div class="flex items-center gap-8">
        <div class="flex items-center gap-2">
            <span class="text-xl">⚡</span>
            <span class="brand-font text-2xl tracking-widest text-accent">FZ ADMIN</span>
        </div>
        <div class="hidden lg:flex gap-6 condensed font-bold tracking-widest text-xs uppercase">
            <a href="/admin" class="nav-link <%= page==='dashboard'?'active':'' %>">Dashboard</a>
            <a href="/admin/plans" class="nav-link <%= page==='plans'?'active':'' %>">Plans</a>
            <a href="/admin/locations" class="nav-link <%= page==='locations'?'active':'' %>">Locations</a>
            <a href="/admin/subscriptions" class="nav-link <%= page==='subs'?'active':'' %>">Subscribers</a>
        </div>
    </div>
    <div class="flex items-center gap-4">
        <div class="text-right hidden md:block">
            <p class="text-[10px] text-muted font-bold uppercase tracking-tighter">System Admin</p>
            <p class="text-xs text-white">Root.User</p>
        </div>
        <div class="w-10 h-10 rounded-full bg-accent/20 border border-accent/40 flex items-center justify-center font-bold">R</div>
    </div>
</nav>
<div class="pt-24"></div>

</body>

</html>
