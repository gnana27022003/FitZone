<%- include('header', { page: 'subs' }) %>

<main class="admin-page-container">
    <div class="flex justify-between items-start section-header">
        <div>
            <h1 class="brand-font text-6xl tracking-tight text-white uppercase">Subscribers</h1>
            <p class="text-muted text-sm tracking-wide uppercase">Monitor Live Transformations</p>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 pb-20">
        
        <% if (subscribers && subscribers.length > 0) { %>
            <% subscribers.forEach(sub => { %>
                <div class="glass-card relative overflow-hidden group p-8">
                    <div class="absolute -right-4 -bottom-4 text-9xl opacity-5 group-hover:opacity-10 transition-opacity">⚡</div>
                    
                    <div class="flex justify-between items-start mb-8">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 bg-accent/20 rounded-xl flex items-center justify-center border border-accent/30 font-bold text-accent uppercase">
                                <%= sub.userId ? sub.userId.name.substring(0, 2) : '??' %>
                            </div>
                            <div>
                                <h4 class="font-bold text-white text-base">
                                    <%= sub.userId ? sub.userId.name : 'Unknown User' %>
                                </h4>
                                <p class="text-[10px] text-muted tracking-widest">
                                    ID: #<%= sub._id.toString().slice(-5).toUpperCase() %>
                                </p>
                            </div>
                        </div>
                        <span class="badge <%= sub.planName.toLowerCase().includes('pro') ? 'badge-blue' : 'badge-orange' %>">
                            <%= sub.planName %>
                        </span>
                    </div>

                    <div class="space-y-4 mb-8">
                        <div class="flex justify-between text-xs">
                            <span class="text-muted uppercase">Status</span>
                            <span class="<%= sub.status === 'active' ? 'text-accent-green' : 'text-red-500' %> font-bold uppercase">
                                <%= sub.status %>
                            </span>
                        </div>
                        <div class="flex justify-between text-xs">
                            <span class="text-muted uppercase">Expiry Date</span>
                            <span class="text-white font-medium">
                                <%= new Date(sub.expiryDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                            </span>
                        </div>
                        <div class="flex justify-between text-xs">
                            <span class="text-muted uppercase">Amount</span>
                            <span class="text-white font-medium">₹<%= sub.price %></span>
                        </div>
                    </div>

                    <a href="/admin/profile/<%= sub.userId ? sub.userId._id : '' %>" class="btn-action btn-edit w-full py-3 text-center block">
                        View Full Profile
                    </a>
                </div>
            <% }); %>
        <% } else { %>
            <div class="col-span-full text-center py-20">
                <p class="text-muted uppercase tracking-widest">No active transformations found.</p>
            </div>
        <% } %>

    </div>
</main>

<%- include('footer') %>