<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Profile | FitZone</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@300;400;600;700&family=Barlow+Condensed:wght@400;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  </head>
  <body>


<%- include('header', { page: 'about' }) %>

<main class="pb-20">
  <div class="section-wrap">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center pt-20 mb-20">
        <div class="reveal-left visible">
            <div class="section-label mb-3 text-accent condensed tracking-widest text-xs font-bold uppercase">🛡️ Our Legacy</div>
            <h1 class="section-title brand-font text-6xl mb-6">Built for Athletes,<br>By Athletes</h1>
            <p class="section-sub text-muted mb-8">Founded in 2019, FitZone started with a simple mission: make premium fitness accessible to everyone, everywhere.</p>
            
            <div class="grid grid-cols-3 gap-4">
                <div class="glass-card p-4 text-center">
                    <div class="counter-num text-3xl brand-font text-accent" data-target="500">500+</div>
                    <div class="stat-label text-[10px] text-muted uppercase">Gyms</div>
                </div>
                <div class="glass-card p-4 text-center">
                    <div class="counter-num text-3xl brand-font text-accent" data-target="128000">128K+</div>
                    <div class="stat-label text-[10px] text-muted uppercase">Members</div>
                </div>
                <div class="glass-card p-4 text-center">
                    <div class="counter-num text-3xl brand-font text-accent" data-target="28">28+</div>
                    <div class="stat-label text-[10px] text-muted uppercase">Cities</div>
                </div>
            </div>
        </div>
        
        <div class="reveal-right visible">
            <div class="glass-card p-2 rotate-2 hover:rotate-0 transition-transform duration-500">
                <div class="aspect-video bg-gradient-to-br from-accent/20 to-accent-hot/20 flex items-center justify-center text-8xl">🏋️‍♂️</div>
            </div>
        </div>
    </div>
  </div>
</main>

<%- include('footer') %>




</body>
</html>