<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Profile | FitZone</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@300;400;600;700&family=Barlow+Condensed:wght@400;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
<%- include('header') %>
  <div class="bg-mesh"></div><div class="bg-grid"></div>
  
  <section class="section-pad pt-8">
    <div class="section-wrap max-w-4xl">
      <div class="text-center mb-10">
        <h1 class="section-title">Athlete Profile</h1>
        <p class="section-sub mx-auto">Track your grind. Level up your life.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
  
  <div class="glass-card p-6 flex flex-col items-center">
    <div class="avatar mb-4" style="width:100px; height:100px; font-size:2.5rem;">🔥</div>
    <h2 class="condensed text-2xl font-bold"><%= user.name %></h2>
    
    <% if (subscription) { %>
      <p class="text-muted text-sm mb-6"><%= subscription.planName %> Plan</p>
    <% } else { %>
      <p class="text-muted text-sm mb-6 text-accent-red uppercase font-bold">Unsubscribed</p>
    <% } %>
    
    <div class="w-full flex flex-col gap-2">
      <a href="/logout" class="btn-outline w-full text-center py-2 text-xs"><span>Logout</span></a>
    </div>
  </div>

  <div class="md:col-span-2 flex flex-col gap-6">
    
    <div class="glass-card p-6">
      <h3 class="condensed text-xl mb-4">Training Metrics</h3>
      <div class="grid grid-cols-3 gap-4">
        <div class="text-center p-4 bg-white/5 rounded-xl border border-white/10">
          <div class="counter-num text-3xl" data-target="47">0</div>
          <p class="stat-label text-[10px]">Workouts</p>
        </div>
        </div>
    </div>
    
    <div class="glass-card p-6">
      <h3 class="condensed text-xl mb-4">Membership Status</h3>
      
      <% if (subscription && subscription.status === 'active') { %>
        <div class="flex justify-between items-center p-4 bg-[#00b4ff10] border border-[#00b4ff30] rounded-xl">
          <div>
            <p class="font-bold text-accent"><%= subscription.planName %></p>
            <p class="text-xs text-muted">
              Expiry: <%= new Date(subscription.expiryDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %>
            </p>
          </div>
          <div class="badge-pill badge-green">Active</div>
        </div>
      <% } else { %>
        <div class="flex flex-col items-center justify-center p-8 border border-dashed border-white/20 rounded-xl bg-white/5">
          <p class="text-muted mb-4 text-center">Your legend hasn't started yet. Join a plan to access elite training.</p>
          <a href="/plans" class="btn-primary"><span>View Membership Plans</span></a>
        </div>
      <% } %>
      
    </div>
  </div>
</div>
    </div>
  </section>
  <%- include('footer') %>
</body>
</html>